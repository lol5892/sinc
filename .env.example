# Токен от @BotFather
BOT_TOKEN=

# Два числовых id через запятую (не телефон, не @ник). Узнать: напиши боту /myid
TELEGRAM_ALLOWED_IDS=123456789,987654321

# Публичный https URL этого приложения (тот же хост, что и API после деплоя), без слэша в конце.
# На Railway/Render/Fly сервер попробует взять публичный домен автоматически, но WEB_APP_URL надёжнее.
# Пример: https://sinc.up.railway.app
WEB_APP_URL=

# Порт API + раздача dist (локально 3001; в облаке часто задаётся платформой)
PORT=3001

# Опционально: вебхук вместо long polling (HTTPS база без слэша)
# WEBHOOK_BASE_URL=https://sinc.up.railway.app
# WEBHOOK_PATH=/telegram/webhook
