# Токен от @BotFather
BOT_TOKEN=

# Два числовых id через запятую (не телефон, не @ник). Узнать: напиши боту /myid
TELEGRAM_ALLOWED_IDS=123456789,987654321

# Публичный https URL этого приложения (тот же хост, что и API после деплоя), без слэша в конце
# Пример: https://sinc.up.railway.app
WEB_APP_URL=

# Порт API + раздача dist (локально 3001; в облаке часто задаётся платформой)
PORT=3001

# Рекомендуемо для продакшена: PostgreSQL
# Railway обычно сам прокидывает DATABASE_URL после добавления Postgres-сервиса
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Папка для events.json. Для Railway Volume обычно: /app/data
# DATA_DIR=/app/data

# Для локальной разработки в браузере без Telegram Mini App
# VITE_DEV_USER_ID должен быть одним из TELEGRAM_ALLOWED_IDS
# VITE_DEV_USER_ID=123456789
# VITE_DEV_USER_NAME=Алексей

# Опционально: вебхук вместо long polling (HTTPS база без слэша)
# WEBHOOK_BASE_URL=https://sinc.up.railway.app
# WEBHOOK_PATH=/telegram/webhook
